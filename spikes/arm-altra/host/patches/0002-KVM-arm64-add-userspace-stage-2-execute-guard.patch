+/*
+ * Per-page response to KVM_EXIT_ARM_STAGE2_EXEC_GUARD.  Userspace may
+ * approve a frozen page for execution after scanning its stable backing, or
+ * reject the execution request and return the page to writable/XN state.
+ */
+struct kvm_arm_stage2_exec_guard {
+	__u64 gpa;
+	__u64 generation;
+	__u32 action;
+	__u32 flags;
+};
+
+#define KVM_ARM_STAGE2_EXEC_GUARD_APPROVE_EXEC	0
+#define KVM_ARM_STAGE2_EXEC_GUARD_REJECT_EXEC	1
+
 #define KVM_ARM_TAGS_TO_GUEST		0
 #define KVM_ARM_TAGS_FROM_GUEST		1
 
