 #ifdef CONFIG_LOCKDEP
 	/* Clue in lockdep that the config_lock must be taken inside kvm->lock */
@@ -260,6 +272,7 @@ void kvm_arch_destroy_vm(struct kvm *kvm)
 
 	kfree(kvm->arch.sysreg_masks);
 	kvm_destroy_vcpus(kvm);
+	xa_destroy(&kvm->arch.exec_guard_pages);
 
 	kvm_unshare_hyp(kvm, kvm + 1);
 
@@ -333,6 +346,7 @@ int kvm_vm_ioctl_check_extension(struct kvm *kvm, long ext)
 	case KVM_CAP_COUNTER_OFFSET:
 	case KVM_CAP_ARM_WRITABLE_IMP_ID_REGS:
 	case KVM_CAP_ARM_DETERMINISTIC_INTERCEPTS:
+	case KVM_CAP_ARM_STAGE2_EXEC_GUARD:
 		r = 1;
 		break;
 	case KVM_CAP_SET_GUEST_DEBUG2:
@@ -1496,6 +1510,12 @@ static int kvm_vcpu_init_check_features(struct kvm_vcpu *vcpu,
 	    test_bit(KVM_ARM_VCPU_PTRAUTH_GENERIC, &features))
 		return -EINVAL;
 
+	/* The execute-guard state machine covers the canonical stage-2 only. */
+	if (test_bit(KVM_ARCH_FLAG_STAGE2_EXEC_GUARD,
+		     &vcpu->kvm->arch.flags) &&
+	    test_bit(KVM_ARM_VCPU_HAS_EL2, &features))
+		return -EINVAL;
+
 	if (!test_bit(KVM_ARM_VCPU_EL1_32BIT, &features))
 		return 0;
 
@@ -1948,6 +1968,17 @@ int kvm_arch_vm_ioctl(struct file *filp, unsigned int ioctl, unsigned long arg)
 			return -EFAULT;
 		return kvm_vm_ioctl_set_counter_offset(kvm, &offset);
 	}
+	case KVM_ARM_STAGE2_EXEC_GUARD: {
