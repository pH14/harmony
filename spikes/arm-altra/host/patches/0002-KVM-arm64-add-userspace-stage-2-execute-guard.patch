diff --git a/arch/arm64/kvm/mmu.c b/arch/arm64/kvm/mmu.c
index 0d38dc72d..db5911d5b 100644
--- a/arch/arm64/kvm/mmu.c
+++ b/arch/arm64/kvm/mmu.c
@@ -343,6 +343,178 @@ void kvm_stage2_unmap_range(struct kvm_s2_mmu *mmu, phys_addr_t start,
 	__unmap_stage2_range(mmu, start, size, may_block);
 }
 
+enum kvm_arm_exec_guard_state {
+	KVM_ARM_EXEC_GUARD_DIRTY,
+	KVM_ARM_EXEC_GUARD_SCANNING,
+	KVM_ARM_EXEC_GUARD_APPROVED,
+};
+
+struct kvm_arm_exec_guard_page {
+	enum kvm_arm_exec_guard_state state;
+	u64 generation;
+};
+
+/* xa_mk_value() consumes one tag bit; the state consumes two value bits. */
+#define KVM_ARM_EXEC_GUARD_GENERATION_MAX	(ULONG_MAX >> 3)
+
+static bool kvm_arm_exec_guard_enabled(struct kvm *kvm)
+{
+	return test_bit(KVM_ARCH_FLAG_STAGE2_EXEC_GUARD, &kvm->arch.flags);
+}
+
+static struct kvm_arm_exec_guard_page
+kvm_arm_exec_guard_state(struct kvm *kvm, gfn_t gfn)
+{
+	struct kvm_arm_exec_guard_page page = {
+		.state = KVM_ARM_EXEC_GUARD_DIRTY,
+	};
+	unsigned long value;
+	void *entry;
+
+	lockdep_assert_held(&kvm->arch.exec_guard_lock);
+	entry = xa_load(&kvm->arch.exec_guard_pages, gfn);
+	if (!entry)
+		return page;
+
+	value = xa_to_value(entry);
+	page.state = value & 3;
+	page.generation = value >> 2;
+	if (page.state != KVM_ARM_EXEC_GUARD_SCANNING &&
+	    page.state != KVM_ARM_EXEC_GUARD_APPROVED) {
+		page.state = KVM_ARM_EXEC_GUARD_DIRTY;
+		page.generation = 0;
+	}
+	return page;
+}
+
+static bool
+kvm_arm_exec_guard_state_matches(struct kvm_arm_exec_guard_page left,
+				 struct kvm_arm_exec_guard_page right)
+{
+	return left.state == right.state &&
+	       left.generation == right.generation;
+}
+
+static bool
+kvm_arm_exec_guard_state_changed(struct kvm *kvm, gfn_t gfn,
+				 struct kvm_arm_exec_guard_page expected)
+{
+	struct kvm_arm_exec_guard_page observed;
+
+	observed = kvm_arm_exec_guard_state(kvm, gfn);
+	return !kvm_arm_exec_guard_state_matches(observed, expected);
+}
+
+static int kvm_arm_exec_guard_set_state(struct kvm *kvm, gfn_t gfn,
+					struct kvm_arm_exec_guard_page page,
+					gfp_t gfp)
+{
+	unsigned long value;
+	void *entry;
+
+	lockdep_assert_held(&kvm->arch.exec_guard_lock);
+	if (page.state == KVM_ARM_EXEC_GUARD_DIRTY) {
+		xa_erase(&kvm->arch.exec_guard_pages, gfn);
+		return 0;
+	}
+	if (!page.generation ||
+	    page.generation > KVM_ARM_EXEC_GUARD_GENERATION_MAX)
+		return -EINVAL;
+
+	value = (page.generation << 2) | page.state;
+	entry = xa_store(&kvm->arch.exec_guard_pages, gfn,
+			 xa_mk_value(value), gfp);
+	return xa_err(entry);
+}
+
+static void kvm_arm_exec_guard_erase_range(struct kvm *kvm,
+					   gfn_t start, gfn_t end)
+{
+	XA_STATE(xas, &kvm->arch.exec_guard_pages, start);
+	void *entry;
+
+	if (start >= end)
+		return;
+
+	/* Advanced XArray deletion is allocation-free and notifier-context safe. */
+	xas_lock(&xas);
+	xas_for_each(&xas, entry, end - 1)
+		xas_store(&xas, NULL);
+	xas_unlock(&xas);
+}
+
+static int kvm_arm_exec_guard_begin_scan(struct kvm *kvm, gfn_t gfn,
+					 struct kvm_arm_exec_guard_page *page)
+{
+	if (kvm->arch.exec_guard_generation ==
+	    KVM_ARM_EXEC_GUARD_GENERATION_MAX)
+		return -EOVERFLOW;
+
+	page->state = KVM_ARM_EXEC_GUARD_SCANNING;
+	page->generation = ++kvm->arch.exec_guard_generation;
+	return kvm_arm_exec_guard_set_state(kvm, gfn, *page,
+					    GFP_KERNEL_ACCOUNT);
+}
+
+static void kvm_arm_exec_guard_unmap(struct kvm *kvm,
+				     struct kvm_s2_mmu *mmu, gpa_t gpa)
+{
+	write_lock(&kvm->mmu_lock);
+	kvm_stage2_unmap_range(mmu, gpa & PAGE_MASK, PAGE_SIZE, true);
+	write_unlock(&kvm->mmu_lock);
+}
+
+int kvm_arm_stage2_exec_guard_apply(struct kvm *kvm, gpa_t gpa,
+				    u64 generation, u32 action)
+{
+	struct kvm_arm_exec_guard_page page;
+	enum kvm_arm_exec_guard_state next;
+	gfn_t gfn;
+	int ret;
+
+	if (!kvm_arm_exec_guard_enabled(kvm) || !generation ||
+	    !PAGE_ALIGNED(gpa) ||
+	    gpa >= kvm_phys_size(&kvm->arch.mmu))
+		return -EINVAL;
+
+	switch (action) {
+	case KVM_ARM_STAGE2_EXEC_GUARD_APPROVE_EXEC:
+		next = KVM_ARM_EXEC_GUARD_APPROVED;
+		break;
+	case KVM_ARM_STAGE2_EXEC_GUARD_REJECT_EXEC:
+		next = KVM_ARM_EXEC_GUARD_DIRTY;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	gfn = gpa >> PAGE_SHIFT;
+	mutex_lock(&kvm->arch.exec_guard_lock);
+	/*
+	 * MMU-notifier invalidation clears approval while holding mmu_lock but
+	 * cannot take exec_guard_lock. Take mmu_lock before the final cookie
+	 * check and state store so backing replacement cannot land between them.
+	 */
+	write_lock(&kvm->mmu_lock);
+	page = kvm_arm_exec_guard_state(kvm, gfn);
+	if (page.state != KVM_ARM_EXEC_GUARD_SCANNING ||
+	    page.generation != generation) {
+		ret = -EINVAL;
+		goto out_mmu_unlock;
+	}
+
+	page.state = next;
+	/* Replacing the existing SCANNING entry must remain non-sleeping. */
+	ret = kvm_arm_exec_guard_set_state(kvm, gfn, page, GFP_ATOMIC);
+	if (!ret)
+		kvm_stage2_unmap_range(&kvm->arch.mmu, gpa, PAGE_SIZE, true);
+
+out_mmu_unlock:
+	write_unlock(&kvm->mmu_lock);
+	mutex_unlock(&kvm->arch.exec_guard_lock);
+	return ret;
+}
+
 void kvm_stage2_flush_range(struct kvm_s2_mmu *mmu, phys_addr_t addr, phys_addr_t end)
 {
 	stage2_apply_range_resched(mmu, addr, end, KVM_PGT_FN(kvm_pgtable_stage2_flush));
@@ -1523,9 +1695,67 @@ static void adjust_nested_fault_perms(struct kvm_s2_trans *nested,
 
 #define KVM_PGTABLE_WALK_MEMABORT_FLAGS (KVM_PGTABLE_WALK_HANDLE_FAULT | KVM_PGTABLE_WALK_SHARED)
 
+/*
+ * Returns 1 when the ordinary fault path may continue, 0 after preparing a
+ * userspace exit, or a negative errno. Called with exec_guard_lock held.
+ */
+static int kvm_arm_exec_guard_fault(struct kvm_vcpu *vcpu,
+				    phys_addr_t fault_ipa, gfn_t gfn,
+				    bool write_fault, bool exec_fault,
+				    struct kvm_arm_exec_guard_page *page)
+{
+	struct kvm *kvm = vcpu->kvm;
+	u64 flags;
+	int ret;
+
+	*page = kvm_arm_exec_guard_state(kvm, gfn);
+	if (exec_fault && page->state != KVM_ARM_EXEC_GUARD_APPROVED) {
+		if (page->state == KVM_ARM_EXEC_GUARD_DIRTY) {
+			ret = kvm_arm_exec_guard_begin_scan(kvm, gfn, page);
+			if (ret)
+				return ret;
+			/* Freeze the bytes before userspace is allowed to scan. */
+			kvm_arm_exec_guard_unmap(kvm, vcpu->arch.hw_mmu,
+						 fault_ipa);
+		}
+
+		vcpu->run->exit_reason = KVM_EXIT_ARM_STAGE2_EXEC_GUARD;
+		vcpu->run->arm_stage2_exec_guard.flags =
+			KVM_ARM_STAGE2_EXEC_GUARD_EXIT_EXEC;
+		vcpu->run->arm_stage2_exec_guard.gpa = fault_ipa & PAGE_MASK;
+		vcpu->run->arm_stage2_exec_guard.generation = page->generation;
+		return 0;
+	}
+
+	if (write_fault && page->state != KVM_ARM_EXEC_GUARD_DIRTY) {
+		flags = KVM_ARM_STAGE2_EXEC_GUARD_EXIT_WRITE;
+		if (page->state == KVM_ARM_EXEC_GUARD_APPROVED) {
+			/* Revoke execute globally before the faulting store retries. */
+			page->state = KVM_ARM_EXEC_GUARD_DIRTY;
+			kvm_arm_exec_guard_set_state(kvm, gfn, *page,
+						     GFP_KERNEL_ACCOUNT);
+			kvm_arm_exec_guard_unmap(kvm, vcpu->arch.hw_mmu,
+						 fault_ipa);
+		} else {
+			/* Keep writes stopped while another vCPU's scan is active. */
+			flags |= KVM_ARM_STAGE2_EXEC_GUARD_EXIT_BLOCKED;
+		}
+
+		vcpu->run->exit_reason = KVM_EXIT_ARM_STAGE2_EXEC_GUARD;
+		vcpu->run->arm_stage2_exec_guard.flags = flags;
+		vcpu->run->arm_stage2_exec_guard.gpa = fault_ipa & PAGE_MASK;
+		vcpu->run->arm_stage2_exec_guard.generation = page->generation;
+		return 0;
+	}
+
+	return 1;
+}
+
 static int gmem_abort(struct kvm_vcpu *vcpu, phys_addr_t fault_ipa,
 		      struct kvm_s2_trans *nested,
-		      struct kvm_memory_slot *memslot, bool is_perm)
+		      struct kvm_memory_slot *memslot, bool is_perm,
+		      bool exec_guard,
+		      struct kvm_arm_exec_guard_page guard_page)
 {
 	bool write_fault, exec_fault, writable;
 	enum kvm_pgtable_walk_flags flags = KVM_PGTABLE_WALK_MEMABORT_FLAGS;
@@ -1565,6 +1795,8 @@ static int gmem_abort(struct kvm_vcpu *vcpu, phys_addr_t fault_ipa,
 	}
 
 	writable = !(memslot->flags & KVM_MEM_READONLY);
+	if (exec_guard)
