arm64: route the generic-timer count through Harmony's work clock

AA-5(c)'s owned arm64 guest cannot use CNTVCT/CNTPCT for time: Neoverse N1
has no ECV trap, so a single reachable live-counter read is a determinism
escape. Keep the architected timer only as the EL1 clock-event interrupt
device and replace all four arm64 count accessors (stable/direct,
physical/virtual) with the materialized Harmony clock page. This covers the
clocksource, sched_clock, delay and erratum CVAL paths through their shared
accessors. Disable the vDSO counter fast path and clear both EL0 counter
enable bits in CNTKCTL_EL1.

The page is reserved and linearly mapped at the owned guest's chosen GPA. The
architected-timer discovery path publishes that address through the ARM one-shot
registration MMIO ABI before registering any clocksource or delay reader,
verifies the host's ABI response, and spins for the first exact-work publication
before boot continues. Its reader requires ABI 1, the exact
materialized|work-derived flags, vcpu 0, and a frequency equal to CNTFRQ_EL0;
malformed or placeholder bytes fail closed to zero rather than falling back to
a live host counter. The post-build empty-allowlist opcode scan is the second
half of this change: it rejects any raw CNTVCT/CNTPCT instruction that survives
configuration.

This patch is Linux-kernel code (GPL-2.0), carried as a diff under the
Harmony repository's designated guest-kernel patch exception.

---
--- a/drivers/clocksource/Kconfig
+++ b/drivers/clocksource/Kconfig
@@ -324,6 +324,20 @@ config ARM_ARCH_TIMER
 	select TIMER_OF if OF
 	select TIMER_ACPI if ACPI
 
+config HARMONY_ARM_PVCLOCK
+	bool "Harmony work-derived arm64 clock page"
+	depends on ARM64 && ARM_ARCH_TIMER
+	default n
+	help
+	  Replace the architected generic counter read used by the arm64
+	  clocksource, sched_clock and delay paths with Harmony's ABI-v1
+	  materialized work-derived page. The generic timer's driver/IRQ slot is
+	  retained for the companion work-clockevent patch. EL0 generic-counter
+	  access and the vDSO fast path are disabled; no live-counter fallback
+	  exists because reachable Neoverse N1 hardware cannot trap CNTVCT.
+
+	  This is a dedicated Harmony guest option. Say N for ordinary kernels.
+
 config ARM_ARCH_TIMER_EVTSTREAM
 	bool "Enable ARM architected timer event stream generation by default"
 	default y if ARM_ARCH_TIMER
--- a/drivers/clocksource/Makefile
+++ b/drivers/clocksource/Makefile
@@ -64,6 +64,7 @@ obj-$(CONFIG_REALTEK_OTTO_TIMER)	+= timer-rtl-otto.o
 
 obj-$(CONFIG_ARC_TIMERS)		+= arc_timer.o
 obj-$(CONFIG_ARM_ARCH_TIMER)		+= arm_arch_timer.o
 obj-$(CONFIG_ARM_ARCH_TIMER)		+= arm_arch_timer_mmio.o
+obj-$(CONFIG_HARMONY_ARM_PVCLOCK) += harmony_arm_pvclock.o
 obj-$(CONFIG_ARM_GLOBAL_TIMER)		+= arm_global_timer.o
 obj-$(CONFIG_ARMV7M_SYSTICK)		+= armv7m_systick.o
--- /dev/null
+++ b/drivers/clocksource/harmony_arm_pvclock.c
@@ -0,0 +1,130 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Harmony's materialized work-derived arm64 clock page.
+ *
+ * The page is reserved from the guest allocator but deliberately retained in
+ * arm64's linear map: the counter accessor is used before general memremap()
+ * allocation is available. The guest publishes that page through a one-shot
+ * MMIO registration surface and waits for the first exact-work stamp before
+ * proceeding. Host updates happen only while the sole vCPU is stopped; the
+ * sequence field keeps the ABI correct for future SMP readers.
+ */
+
+#include <linux/types.h>
+#include <linux/compiler.h>
+#include <linux/init.h>
+#include <linux/io.h>
+#include <linux/panic.h>
+#include <linux/printk.h>
+
+#include <asm/arch_timer.h>
+#include <asm/barrier.h>
+#include <asm/byteorder.h>
+#include <asm/memory.h>
+#include <asm/processor.h>
+
+#define HARMONY_PVCLOCK_GPA		0x40001000ULL
+#define HARMONY_PVCLOCK_REGISTER_GPA	0x0b000000ULL
+#define HARMONY_PVCLOCK_REGISTER_SIZE	0x1000
+#define HARMONY_PVCLOCK_REGISTER_ABI	0x8
+#define HARMONY_PVCLOCK_REGISTER_SPINS	(1U << 28) /* host caps delta at 100M work */
+#define HARMONY_PVCLOCK_ABI		1U
+#define HARMONY_FLAG_MATERIALIZED	(1U << 0)
+#define HARMONY_FLAG_WORK_DERIVED	(1U << 1)
+#define HARMONY_FLAGS_V1 \
+	(HARMONY_FLAG_MATERIALIZED | HARMONY_FLAG_WORK_DERIVED)
+
+struct harmony_arm_pvclock_page {
+	__le32 abi_version;
+	__le32 seq;
+	__le64 vns;
+	__le64 guest_clock;
+	__le64 guest_clock_hz;
+	__le32 flags;
+	__le32 vcpu_index;
+} __packed;
+
+/* Set once registration has validated the page; guards reads before its
+ * linear mapping exists (an early counter read would otherwise fault). */
+static bool harmony_pvclock_ready __ro_after_init;
+
+static __always_inline const struct harmony_arm_pvclock_page *harmony_page(void)
+{
+	return (const void *)__phys_to_virt(HARMONY_PVCLOCK_GPA);
+}
+
+static __always_inline bool harmony_page_valid(void)
+{
+	const struct harmony_arm_pvclock_page *p = harmony_page();
+
+	return le32_to_cpu(READ_ONCE(p->abi_version)) == HARMONY_PVCLOCK_ABI &&
+	       le32_to_cpu(READ_ONCE(p->flags)) == HARMONY_FLAGS_V1 &&
+	       le32_to_cpu(READ_ONCE(p->vcpu_index)) == 0 &&
+	       le64_to_cpu(READ_ONCE(p->guest_clock_hz)) ==
+			arch_timer_get_cntfrq();
+}
+
+/*
+ * Registration is deliberately not a stamping Moment: KVM's natural MMIO
+ * exit carries skid. The host records the validated GPA and publishes only at
+ * the next exact forced landing. This bounded deterministic spin retires work
+ * until that canonical publication appears; it never consults wall time.
+ */
+void __init harmony_arm_pvclock_register(void)
+{
+	void __iomem *registers;
+	u32 abi;
+	u32 spin;
+
+	registers = ioremap(HARMONY_PVCLOCK_REGISTER_GPA,
+			    HARMONY_PVCLOCK_REGISTER_SIZE);
+	if (!registers)
+		panic("Harmony pvclock registration MMIO cannot be mapped");
+
+	writeq(HARMONY_PVCLOCK_GPA, registers);
+	abi = readl(registers + HARMONY_PVCLOCK_REGISTER_ABI);
+	iounmap(registers);
+	if (abi != HARMONY_PVCLOCK_ABI)
+		panic("Harmony pvclock host returned ABI %u, expected %u",
+		      abi, HARMONY_PVCLOCK_ABI);
+
+	for (spin = 0; spin < HARMONY_PVCLOCK_REGISTER_SPINS; spin++) {
+		if (harmony_page_valid()) {
+			WRITE_ONCE(harmony_pvclock_ready, true);
+			pr_info("Harmony pvclock: registered page %#llx (ABI %u)\n",
+				HARMONY_PVCLOCK_GPA, HARMONY_PVCLOCK_ABI);
+			return;
+		}
+		cpu_relax();
+	}
+	panic("Harmony pvclock registration was accepted but no exact-work stamp arrived");
+}
+
+/*
+ * Return the virtual generic-counter value. Zero is the fail-closed value:
+ * this dedicated kernel has no raw-counter fallback, and the build gate
+ * rejects one if a future edit adds it.
+ */
+noinstr u64 harmony_arm_pvclock_read(void)
+{
+	const struct harmony_arm_pvclock_page *p = harmony_page();
+	u32 seq;
+	u64 count;
+
+	if (!READ_ONCE(harmony_pvclock_ready))
+		return 0;
+
+	if (!harmony_page_valid())
+		return 0;
+
+	do {
+		do {
+			seq = le32_to_cpu(READ_ONCE(p->seq));
+		} while (seq & 1);
+		smp_rmb();
+		count = le64_to_cpu(READ_ONCE(p->guest_clock));
+		smp_rmb();
+	} while (le32_to_cpu(READ_ONCE(p->seq)) != seq);
+
+	return count;
+}
--- a/arch/arm64/include/asm/arch_timer.h
+++ b/arch/arm64/include/asm/arch_timer.h
@@ -167,6 +167,30 @@ static inline void arch_timer_set_cntkctl(u32 cntkctl)
 	isb();
 }
 
+#ifdef CONFIG_HARMONY_ARM_PVCLOCK
+u64 harmony_arm_pvclock_read(void);
+void __init harmony_arm_pvclock_register(void);
+
+static __always_inline u64 __arch_counter_get_cntpct_stable(void)
+{
+	return harmony_arm_pvclock_read();
+}
+
+static __always_inline u64 __arch_counter_get_cntpct(void)
+{
+	return harmony_arm_pvclock_read();
+}
+
+static __always_inline u64 __arch_counter_get_cntvct_stable(void)
+{
+	return harmony_arm_pvclock_read();
+}
+
+static __always_inline u64 __arch_counter_get_cntvct(void)
+{
+	return harmony_arm_pvclock_read();
+}
+#else
 static __always_inline u64 __arch_counter_get_cntpct_stable(void)
 {
 	u64 cnt;
@@ -208,6 +231,7 @@ static __always_inline u64 __arch_counter_get_cntvct(void)
 	arch_counter_enforce_ordering(cnt);
 	return cnt;
 }
+#endif
 
 static inline int arch_timer_arch_init(void)
 {
--- a/arch/arm64/include/asm/vdso/gettimeofday.h
+++ b/arch/arm64/include/asm/vdso/gettimeofday.h
@@ -73,12 +73,17 @@ static __always_inline u64 __arch_get_hw_counter(s32 clock_mode,
 						 const struct vdso_time_data *vd)
 {
+#ifdef CONFIG_HARMONY_ARM_PVCLOCK
+	/* The page is kernel-only; vdso_default forces the syscall path. */
+	return 0;
+#else
 	/*
 	 * Core checks for mode already, so this raced against a concurrent
 	 * update. Return something. Core will do another round and then
 	 * see the mode change and fallback to the syscall.
 	 */
 	if (clock_mode == VDSO_CLOCKMODE_NONE)
 		return 0;
 
 	return __arch_counter_get_cntvct();
+#endif
 }
--- a/drivers/clocksource/arm_arch_timer.c
+++ b/drivers/clocksource/arm_arch_timer.c
@@ -57,7 +57,9 @@ static enum arch_timer_ppi_nr arch_timer_uses_ppi __ro_after_init = ARCH_TIMER_V
 static bool arch_timer_c3stop __ro_after_init;
 static bool arch_counter_suspend_stop __ro_after_init;
 #ifdef CONFIG_GENERIC_GETTIMEOFDAY
-static enum vdso_clock_mode vdso_default = VDSO_CLOCKMODE_ARCHTIMER;
+static enum vdso_clock_mode vdso_default =
+	IS_ENABLED(CONFIG_HARMONY_ARM_PVCLOCK) ? VDSO_CLOCKMODE_NONE :
+	VDSO_CLOCKMODE_ARCHTIMER;
 #else
 static enum vdso_clock_mode vdso_default = VDSO_CLOCKMODE_NONE;
 #endif /* CONFIG_GENERIC_GETTIMEOFDAY */
@@ -151,7 +153,8 @@ static struct clocksource clocksource_counter = {
-	.name	= "arch_sys_counter",
+	.name	= IS_ENABLED(CONFIG_HARMONY_ARM_PVCLOCK) ?
+		"harmony-arm-pvclock" : "arch_sys_counter",
 	.id	= CSID_ARM_ARCH_COUNTER,
 	.rating	= 400,
 	.read	= arch_counter_read,
 	.flags	= CLOCK_SOURCE_IS_CONTINUOUS,
 };
 
@@ -791,15 +794,17 @@ static void arch_counter_set_user_access(void)
 			| ARCH_TIMER_VIRT_EVT_EN
 			| ARCH_TIMER_USR_PCT_ACCESS_EN);
 
-	/*
-	 * Enable user access to the virtual counter if it doesn't
-	 * need to be workaround. The vdso may have been already
-	 * disabled though.
-	 */
-	if (arch_timer_this_cpu_has_cntvct_wa())
+	if (IS_ENABLED(CONFIG_HARMONY_ARM_PVCLOCK)) {
+		/*
+		 * N1 cannot trap EL0 CNTVCT at EL2. Deny it at EL1 and force
+		 * clock_gettime through the syscall/page-backed clocksource.
+		 */
+		pr_info_once("Harmony clock: denying EL0 generic-counter access\n");
+	} else if (arch_timer_this_cpu_has_cntvct_wa()) {
 		pr_info("CPU%d: Trapping CNTVCT access\n", smp_processor_id());
-	else
+	} else {
 		cntkctl |= ARCH_TIMER_USR_VCT_ACCESS_EN;
+	}
 
 	arch_timer_set_cntkctl(cntkctl);
 }
@@ -1136,6 +1141,10 @@ static int __init arch_timer_of_init(struct device_node *np)
 		pr_warn("multiple nodes in dt, skipping\n");
 		return 0;
 	}
+
+#ifdef CONFIG_HARMONY_ARM_PVCLOCK
+	harmony_arm_pvclock_register();
+#endif
 
 	has_names = of_property_present(np, "interrupt-names");
 
