+++ b/arch/arm64/kernel/process.c
@@ -662,6 +662,7 @@ static void update_cntkctl_el1(struct task_struct *next)
 	struct thread_info *ti = task_thread_info(next);
 
-	if (test_ti_thread_flag(ti, TIF_TSC_SIGSEGV) ||
