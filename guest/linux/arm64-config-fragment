# AA-5(c) arm64 guest-kernel determinism overlay. Merged after arm64 tinyconfig;
# build-arm64-kernel.sh asserts every load-bearing result after olddefconfig.

## Reproducible identity and placement
CONFIG_64BIT=y
CONFIG_LOCALVERSION=""
# CONFIG_LOCALVERSION_AUTO is not set
# CONFIG_RANDOMIZE_BASE is not set

## Deterministic CRNG seed. The guest's only non-work entropy source is the
## timing-jitter harvester (try_to_generate_entropy), driven by the wall-clock
## hrtimer, which breaks same-seed state identity (AA-5, 2026-07-20). Crediting the
## fixed /chosen/rng-seed the harness DTB provides as full entropy makes crng_ready()
## hold before wait_for_random_bytes, so the jitter loop never runs.
CONFIG_RANDOM_TRUST_BOOTLOADER=y
# CONFIG_RANDOM_TRUST_CPU is not set

## One DT-presented vCPU and no autonomous host-frequency policy
# arm64 v6.18 makes CONFIG_SMP unconditional and NR_CPUS has a minimum of 2;
# the harness still exposes exactly one CPU node and creates exactly one vCPU.
CONFIG_NR_CPUS=2
# CONFIG_HOTPLUG_CPU is not set
# CONFIG_CPU_FREQ is not set
# CONFIG_CPU_IDLE is not set

## LSE-only atomic contract
# The N1 exposes FEAT_LSE. The owned patch removes the runtime LL/SC atomic
# alternative and reservation-monitor wait hints; the publication gate scans
# every executable word in vmlinux and the vDSO for any surviving exclusive.
CONFIG_ARM64_USE_LSE_ATOMICS=y
CONFIG_HARMONY_ARM_LSE_ONLY=y

## Fixed periodic scheduling surface
CONFIG_HZ_PERIODIC=y
CONFIG_HZ_100=y
# CONFIG_HIGH_RES_TIMERS is not set
# CONFIG_NO_HZ_COMMON is not set
# CONFIG_NO_HZ_IDLE is not set
# CONFIG_NO_HZ_FULL is not set

## Owned clock and interrupt path
# The AA-5(c) patch replaces every live generic-counter read with the materialized
# work-derived page and uses the timer driver's IRQ slot only for dedicated PPI 20;
# it never programs live-domain CNTV_CVAL/TVAL. `nohlt` is mandatory in the DT so
# the sole vCPU polls and keeps exact work targets reachable instead of entering WFI.
CONFIG_ARM_ARCH_TIMER=y
CONFIG_HARMONY_ARM_PVCLOCK=y
CONFIG_GENERIC_IDLE_POLL_SETUP=y
# All selectors of the out-of-line raw-counter workaround must be off. The
# shipped N1 target needs none of these unrelated SoC/core errata paths.
# CONFIG_FSL_ERRATUM_A008585 is not set
# CONFIG_HISILICON_ERRATUM_161010101 is not set
# CONFIG_ARM64_ERRATUM_858921 is not set
# CONFIG_SUN50I_ERRATUM_UNKNOWN1 is not set
CONFIG_ARM_PSCI_FW=y
CONFIG_IRQCHIP=y
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V3=y

## DT boot, PL011 console, and external gzip initramfs
CONFIG_OF=y
CONFIG_PRINTK=y
CONFIG_TTY=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_BINFMT_ELF=y
# CONFIG_BINFMT_SCRIPT is not set
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
# CONFIG_RD_ZSTD is not set
# The freestanding /init uses raw syscalls and sysfs only: no shell, libc,
# BusyBox, script interpreter, procfs, or userspace threading primitives.
# CONFIG_PROC_FS is not set
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
# CONFIG_FUTEX is not set
CONFIG_POSIX_TIMERS=y
CONFIG_STRICT_KERNEL_RWX=y

## Determinism exclusions
# CONFIG_MODULES is not set
# CONFIG_BPF_SYSCALL is not set
# CONFIG_BPF_JIT is not set
# CONFIG_KPROBES is not set
# CONFIG_FUNCTION_TRACER is not set
# CONFIG_FTRACE is not set
# CONFIG_LIVEPATCH is not set
# CONFIG_PERF_EVENTS is not set
# CONFIG_HW_PERF_EVENTS is not set
# CONFIG_HW_RANDOM is not set
# CONFIG_TRANSPARENT_HUGEPAGE is not set
# CONFIG_KSM is not set
# CONFIG_SUSPEND is not set
# CONFIG_HIBERNATION is not set
