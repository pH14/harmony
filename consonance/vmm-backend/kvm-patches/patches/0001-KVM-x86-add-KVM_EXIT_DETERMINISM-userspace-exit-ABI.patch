From 4f4d541511fbb8099767a405f4247f30d2b2926e Mon Sep 17 00:00:00 2001
From: spike <s@s>
Date: Tue, 23 Jun 2026 15:01:13 +0200
Subject: [PATCH 1/3] KVM: x86: add KVM_EXIT_DETERMINISM userspace exit ABI

Define the userspace ABI for deterministically intercepting
RDTSC/RDTSCP/RDRAND/RDSEED: a new KVM_EXIT_DETERMINISM exit reason, the
kvm_run.determinism payload (instruction kind + result width out; value,
TSC_AUX, and a CF success flag in; RNG destination GPR out), and the
opt-in capability KVM_CAP_X86_DETERMINISTIC_INTERCEPTS.  No behavior
change on its own.

Co-developed-for: harmony PatchedKvmBackend (docs/R-BACKEND.md)
---
 include/uapi/linux/kvm.h | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/include/uapi/linux/kvm.h b/include/uapi/linux/kvm.h
index 954e0511c..82c157244 100644
--- a/include/uapi/linux/kvm.h
+++ b/include/uapi/linux/kvm.h
@@ -184,6 +184,7 @@ struct kvm_xen_exit {
 #define KVM_EXIT_LOONGARCH_IOCSR  38
 #define KVM_EXIT_MEMORY_FAULT     39
 #define KVM_EXIT_TDX              40
+#define KVM_EXIT_DETERMINISM      41
 
 /* For KVM_EXIT_INTERNAL_ERROR */
 /* Emulate instruction failed. */
@@ -478,6 +479,21 @@ struct kvm_run {
 				} setup_event_notify;
 			};
 		} tdx;
+		/* KVM_EXIT_DETERMINISM */
+		struct {
+#define KVM_DETERMINISM_RDTSC	0
+#define KVM_DETERMINISM_RDTSCP	1
+#define KVM_DETERMINISM_RDRAND	2
+#define KVM_DETERMINISM_RDSEED	3
+			__u32 insn;     /* kernel -> user: KVM_DETERMINISM_* */
+			__u32 width;    /* kernel -> user: result width in bytes */
+			__u64 value;    /* user -> kernel: low `width` bytes -> dest / EDX:EAX */
+			__u64 aux;      /* RDTSCP: user -> kernel IA32_TSC_AUX -> ECX */
+#define KVM_DETERMINISM_FLAG_CF	(1 << 0) /* RNG: user requests CF=1 (success) */
+			__u8 flags;     /* user -> kernel */
+			__u8 dest_reg;  /* kernel -> user: RNG dest GPR (0=RAX..15=R15) */
+			__u8 pad[6];
+		} determinism;
 		/* Fix the size of the union. */
 		char padding[256];
 	};
@@ -968,6 +984,7 @@ struct kvm_enable_cap {
 #define KVM_CAP_RISCV_MP_STATE_RESET 242
 #define KVM_CAP_ARM_CACHEABLE_PFNMAP_SUPPORTED 243
 #define KVM_CAP_GUEST_MEMFD_FLAGS 244
+#define KVM_CAP_X86_DETERMINISTIC_INTERCEPTS 245
 
 struct kvm_irq_routing_irqchip {
 	__u32 irqchip;
-- 
