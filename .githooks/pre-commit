#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Repository-managed entry point for .pre-commit-config.yaml. The project uses
# core.hooksPath=.githooks, so `pre-commit install` must not replace this file.
set -euo pipefail

if ! command -v pre-commit >/dev/null 2>&1; then
    echo "pre-commit is required for Harmony's credential-leak check." >&2
    echo "Install it with 'brew install pre-commit' or 'pipx install pre-commit'." >&2
    echo "Then run 'pre-commit install-hooks'." >&2
    exit 1
fi

exec pre-commit run --hook-stage pre-commit
