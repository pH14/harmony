#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v1.1.0 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  _bd_timeout=${BEADS_HOOK_TIMEOUT:-300}
  _bd_used_perl=0
  if command -v timeout >/dev/null 2>&1; then
    timeout "$_bd_timeout" bd hooks run pre-commit "$@"
    _bd_exit=$?
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$_bd_timeout" bd hooks run pre-commit "$@"
    _bd_exit=$?
  elif command -v perl >/dev/null 2>&1; then
    _bd_used_perl=1
    perl -e 'alarm shift; exec @ARGV' "$_bd_timeout" bd hooks run pre-commit "$@"
    _bd_exit=$?
  else
    echo >&2 "beads: hook 'pre-commit' running without timeout; install coreutils or perl to enable BEADS_HOOK_TIMEOUT"
    bd hooks run pre-commit "$@"
    _bd_exit=$?
  fi
  if [ $_bd_exit -eq 124 ] || { [ $_bd_used_perl -eq 1 ] && [ $_bd_exit -eq 142 ]; }; then
    echo >&2 "beads: hook 'pre-commit' timed out after ${_bd_timeout}s — continuing without beads"
    _bd_exit=0
  fi
  if [ $_bd_exit -eq 3 ]; then
    echo >&2 "beads: database not initialized — skipping hook 'pre-commit'"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.1.0 ---

# --- HARMONY CREDENTIAL-SCAN CHAIN (outside the beads-managed section; survives
# `bd hooks install` regeneration of the marked block above). When core.hooksPath
# points HERE (beads installed last), the .githooks/pre-commit entry never runs,
# so the credential stage must run from this side too (review F3, verify-event
# finding). When hooksPath is .githooks (the documented setup), that entry runs
# the stage itself and delegates to this file only for the beads section — the
# guard below keeps the scan from running twice.
if [ "$(git config core.hooksPath 2>/dev/null)" != ".githooks" ]; then
  if command -v pre-commit >/dev/null 2>&1; then
    pre-commit run --hook-stage pre-commit || exit $?
  else
    echo "pre-commit is required for Harmony's credential-leak check (docs/SECRET-HYGIENE.md)." >&2
    echo "Install it with 'brew install pre-commit' or 'pipx install pre-commit', then 'pre-commit install-hooks'." >&2
    exit 1
  fi
fi
# --- END HARMONY CREDENTIAL-SCAN CHAIN ---
